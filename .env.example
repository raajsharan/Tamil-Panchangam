# ===========================================
# Tamil Calendar & Panchangam - Environment Configuration
# ===========================================

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
# Local: postgresql://username:password@localhost:5432/tamil_calendar
# Cloud (Neon/Supabase): postgresql://user:pass@host.region.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tamil_calendar?schema=public"

# -------------------------------------------
# Backend API
# -------------------------------------------
API_PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# Frontend
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SITE_NAME="Tamil Calendar"
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------
# Telegram Bot
# -------------------------------------------
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
# Webhook URL for production (leave empty for polling mode in development)
TELEGRAM_WEBHOOK_URL=
# Admin chat ID for notifications (get via /getme or @userinfobot)
ADMIN_CHAT_ID=

# -------------------------------------------
# Scraper Configuration
# -------------------------------------------
# Delay between scrape attempts (ms)
SCRAPER_DELAY_MS=3000
# Maximum retry attempts
SCRAPER_MAX_RETRIES=3
# Request timeout (ms)
SCRAPER_TIMEOUT_MS=30000

# -------------------------------------------
# Cron Scheduler
# -------------------------------------------
# Daily scrape time (IST) - Default: 4:30 AM
CRON_SCHEDULE="30 4 * * *"
# Telegram notification time (IST) - Default: 5:00 AM
TELEGRAM_POST_SCHEDULE="0 5 * * *"

# -------------------------------------------
# Excel Export (Bonus Feature)
# -------------------------------------------
EXCEL_EXPORT_PATH=./exports

# -------------------------------------------
# Tamil TTS (Bonus Feature)
# -------------------------------------------
# Optional: Azure TTS or Google TTS API key
AZURE_TTS_KEY=""
AZURE_TTS_REGION="eastus"
